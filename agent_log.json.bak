    },
    {
      "timestamp": "2026-02-25T16:00:00Z",
      "type": "decision",
      "title": "Chose Apache 2.0 + public good positioning over commercial licensing",
      "description": "Independently evaluated BSL, Core-EE, and Apache 2.0 licensing strategies. Recommended Apache 2.0 full open source with public good positioning. Rationale: trust infrastructure that charges for access undermines its own premise. Switched SUBMISSION.md narrative from commercial to public good.",
      "outcome": "LICENSE: Apache-2.0. FUNDING.yml added. README public good section written.",
