# ── Required (nothing breaks without these, but signals are limited) ───────────

# GitHub — higher rate limits (60 → 5000 req/hr)
GITHUB_TOKEN=

# Twitter/X — enables social presence signals
TWITTER_BEARER_TOKEN=

# Moltbook — enables agent community reputation signals
MOLTBOOK_API_KEY=

# ── EAS Attestation (optional) ─────────────────────────────────────────────────

# Set to true to write trust scores on-chain via EAS on Base Mainnet
ATTESTATION_ENABLED=false

# Private key of the wallet used for BOTH:
#   - Signing EAS attestation transactions (spends ETH for gas)
#   - Receiving x402 USDC payments (the address is derived automatically)
# Same wallet, one key. Fund it with a small amount of Base ETH for gas.
TRSTLYR_ATTESTATION_PRIVATE_KEY=

# ── API config ────────────────────────────────────────────────────────────────

# Public base URL of this API instance (used in x402 payment resources)
BASE_URL=https://api.trstlyr.ai

# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Required in production — persists identity links, x402 free tier, nonces
# Falls back to in-memory if not set (data lost on restart)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
