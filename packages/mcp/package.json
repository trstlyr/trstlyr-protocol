{
  "name": "@trstlyr/mcp",
  "version": "0.1.0",
  "description": "TrstLyr MCP server \u2014 trust queries for AI agents",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "trstlyr-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "echo 'build with pnpm build'"
  },
  "dependencies": {
    "@trstlyr/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
